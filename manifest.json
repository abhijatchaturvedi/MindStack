{
  "manifest_version": 3,
  "name": "MindStack",
  "description": "A professional memory development workspace for capturing, reviewing, and resurfacing knowledge from the web.",
  "version": "1.0.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "MindStack",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "permissions": ["activeTab", "contextMenus", "storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "capture-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Capture selected text into MindStack"
    },
    "save-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Save the current webpage to MindStack"
    },
    "open-dashboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "Open MindStack dashboard"
    }
  }
}
